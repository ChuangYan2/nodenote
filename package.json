{
	"name": "idea-inbox",
	"publisher": "waveye",
	"displayName": "Idea Inbox",
	"description": "A triage notebook for markdown: per-cell status flags and question/answer cells.",
	"version": "0.7.2",
	"preview": true,
	"engines": {
		"vscode": "^1.75.0"
	},
	"repository": {
		"url": "https://github.com/microsoft/vscode-markdown-notebook"
	},
	"categories": [
		"Other"
	],
	"main": "./out/extension.js",
	"browser": "./out/extension-bundle.js",
	"capabilities": {
		"virtualWorkspaces": true,
		"untrustedWorkspaces": {
			"supported": true
		}
	},
	"contributes": {
		"customEditors": [
			{
				"viewType": "ideaInbox.editor",
				"displayName": "Idea Inbox",
				"priority": "option",
				"selector": [
					{
						"filenamePattern": "*.{md,markdown}"
					}
				]
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile && npm run bundle",
		"compile": "tsc -p ./",
		"lint": "eslint src",
		"deploy": "npx vsce publish --noVerify",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"test": "node ./out/test/runTest.js",
		"test:core": "node --experimental-strip-types --test src/core/*.test.ts",
		"bundle": "npx esbuild src/extension.ts --bundle --outfile=out/extension-bundle.js --platform=node --external:vscode"
	},
	"devDependencies": {
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.0.0",
		"@types/vscode": "^1.75.0",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"@vscode/test-electron": "^2.5.2",
		"esbuild": "^0.28.1",
		"eslint": "^10.1.0",
		"glob": "^13.0.6",
		"mocha": "^11.7.5",
		"typescript": "^5.9.3"
	}
}
